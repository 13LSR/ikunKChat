# Public frontend configuration
# This value is safe to expose because it is only the Worker endpoint.
VITE_WORKER_API_BASE_URL="https://ikunkchat-ai-proxy.your-account.workers.dev"

# Optional public default title model. It must exist in the Worker model list.
VITE_TITLE_MODEL_NAME="model-a"

# Do not configure API keys or access passwords as frontend env variables.
# Direct manual API testing should be done from the in-app advanced settings only.
# Production secrets belong in Cloudflare Worker secrets.
